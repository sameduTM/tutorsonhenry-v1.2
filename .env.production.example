# Production Environment Variables
# Copy this file to .env and fill in your production values

# Node Environment
NODE_ENV=production

# Server Configuration
PORT=3000
DOMAIN=yourdomain.com

# Database
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/tutorsonDB?retryWrites=true&w=majority

# Session & Security
SESSION_SECRET=your_super_secret_session_key_min_32_chars

# Google OAuth (Get from Google Cloud Console)
# https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your_google_client_id_here.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_CALLBACK_URL=https://yourdomain.com/auth/google/callback

# Email Configuration (Optional - for order notifications)
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_specific_password

# PayPal Configuration (If using PayPal payments)
PAYPAL_MODE=live
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_secret

# Redis Configuration (Optional - for caching)
REDIS_URL=redis://localhost:6379

# Logging
LOG_LEVEL=error

# CORS Settings
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
